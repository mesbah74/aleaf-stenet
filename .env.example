# Optional: path to the trained ALeaf-STENet checkpoint.
# Default is aleaf_best.pth beside app.py.
ALEAF_MODEL_PATH="aleaf_best.pth"

# Optional severity normalization: auto, sigmoid, fraction, or percent.
ALEAF_SEVERITY_MODE="auto"

# Optional timm backbone names. Keep these defaults for the supplied checkpoint.
ALEAF_EFFNET_NAME="tf_efficientnetv2_s"
ALEAF_SWIN_NAME="swin_tiny_patch4_window7_224"
